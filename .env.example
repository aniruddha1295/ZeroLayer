# claw-pin environment configuration
# Copy this file to .env and fill in your values

# Filecoin Pay Mainnet Wallet Address (Dev 2 will provide this)
WALLET_ADDRESS=

# Filecoin Pin API Key (if required by real SDK)
FILECOIN_PIN_API_KEY=

# Enable debug logging (set to "true" to show raw error stacks)
DEBUG=false
